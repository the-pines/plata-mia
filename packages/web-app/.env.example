# Required — 'testnet' or 'mainnet'
NEXT_PUBLIC_NETWORK=testnet

# Required — announcement proxy server
NEXT_PUBLIC_XX_PROXY_URL=http://localhost:8080

# Optional — Alchemy API key for better RPC (falls back to public RPCs)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Optional — custom Hyperbridge indexer URL
NEXT_PUBLIC_HYPERBRIDGE_INDEXER=
