# Required — path to xx-network mainnet certificate
# Get from: https://github.com/Elixxir-io/client/blob/release/cmd/deployment.go (mainNetCert)
XX_CERT_PATH=./mainnet.crt

# Required — password for cMix session encryption
XX_PASSWORD=your-session-password

# Session persistence directory
XX_SESSION_DIR=./xx-session

# Broadcast channel name
XX_CHANNEL_NAME=platamiaannouncements

# Pre-generated channel PrettyPrint (leave empty to create new)
XX_CHANNEL_PRINT=

# File to persist channel PrettyPrint across restarts
XX_CHANNEL_FILE=./channel.txt

# Directory for announcement storage
XX_DATA_PATH=./data

# HTTP server port
PORT=8080

# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000

# Rate limit for /announce endpoint (requests/second)
ANNOUNCE_RATE_LIMIT=10
